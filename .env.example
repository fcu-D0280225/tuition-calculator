# 複製此檔為 .env 即可載入：cp .env.example .env
# .env 已被 .gitignore 排除，敏感值不會被提交。
# 所有變數皆為「選填」，未設定時會使用 server/db.js / server/index.js 的預設值。

# ── 後端 HTTP ──
PORT=3100

# ── MySQL ──
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=tuition_calculator

# ── AI 助理 ──
# 前往 https://console.anthropic.com/ 取得 API Key
# ANTHROPIC_API_KEY=sk-ant-...

# ── 前端 dev server (vite.config.js 用) ──
# 設定後 vite 開發/preview 會把 /api 反向代理到此處；本機同台時可省略。
# VITE_API_TARGET=http://localhost:3100
